generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Video {
  id           String   @id
  title        String
  thumbnailUrl String
  createdAt    DateTime
  duration     Int
  views        Int
  tags         Tag[]
}

model Tag {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  videos Video[]
}
