{
  "name": "veed-api",
  "version": "1.0.0",
  "scripts": {
    "dev": "tsx --tsconfig tsconfig.json src/index.ts",
    "build": "prisma generate && tsc",
    "start": "prisma migrate deploy && npx tsx prisma/seed.ts && node dist/src/index.js",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.1",
    "@prisma/client": "^6.19.3",
    "@trpc/server": "^11.16.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.4",
    "prisma": "^6.19.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0"
  }
}
